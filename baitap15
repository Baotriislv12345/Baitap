from datetime import datetime, timedelta

# nhập ngày
d, m, y = map(int, input("Nhap ngay thang nam: ").split())

date = datetime(y, m, d)

# ngày sau
tomorrow = date + timedelta(days=1)

# ngày trước
yesterday = date - timedelta(days=1)

print("Hom sau:", tomorrow.day, tomorrow.month, tomorrow.year)
print("Hom truoc:", yesterday.day, yesterday.month, yesterday.year)