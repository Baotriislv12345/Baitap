import random   # thư viện sinh số ngẫu nhiên

# điểm của người và máy
human_score = 0
computer_score = 0

while True:
    # nhập lựa chọn của người
    human = input("Nhap (b=bao, d=da, k=keo, ky tu khac de thoat): ")

    # nếu nhập khác b,d,k thì thoát
    if human not in ["b", "d", "k"]:
        break

    # máy chọn ngẫu nhiên
    computer = random.choice(["b", "d", "k"])

    print("Computer:", computer)

    # xét kết quả
    if human == computer:
        print("Hoa")

    elif (human == "b" and computer == "d") or \
         (human == "d" and computer == "k") or \
         (human == "k" and computer == "b"):
        
        print("Ban thang")
        human_score += 1

    else:
        print("May thang")
        computer_score += 1

    # in tỷ số
    print("Ty so human - computer:", human_score, "-", computer_score)